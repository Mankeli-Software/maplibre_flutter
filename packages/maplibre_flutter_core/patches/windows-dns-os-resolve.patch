+#ifdef _WIN32
+namespace {
+// curl's asynchronous DNS resolvers do not work under our libuv-driven curl
+// multi-socket loop on Windows: the default threaded resolver never delivers
+// completion (requests hang before any socket opens), and the c-ares resolver
+// fails to discover the system nameservers. Either way DNS never resolves, so
+// styles/tiles never load and the map stays blank. Work around it by resolving
+// through the OS resolver (getaddrinfo — always reflects the current system DNS
+// config; handles IPv4/IPv6 and network changes) and pre-seeding curl's address
+// cache with CURLOPT_RESOLVE, which makes curl skip its own resolver entirely.
+// Returns a curl_slist the caller owns (curl_slist_free_all), or nullptr.
+curl_slist *resolveHostViaOS(const std::string &url) {
+    CURLU *u = curl_url();
+    if (!u) {
+        return nullptr;
+    }
+    curl_slist *out = nullptr;
+    char *host = nullptr;
+    char *port = nullptr;
+    if (curl_url_set(u, CURLUPART_URL, url.c_str(), 0) == CURLUE_OK &&
+        curl_url_get(u, CURLUPART_HOST, &host, 0) == CURLUE_OK &&
+        curl_url_get(u, CURLUPART_PORT, &port, CURLU_DEFAULT_PORT) == CURLUE_OK) {
+        struct addrinfo hints;
+        memset(&hints, 0, sizeof(hints));
+        hints.ai_socktype = SOCK_STREAM;
+        struct addrinfo *res = nullptr;
+        if (getaddrinfo(host, port, &hints, &res) == 0) {
+            std::string entry = std::string(host) + ":" + port + ":";
+            bool any = false;
+            for (struct addrinfo *a = res; a != nullptr; a = a->ai_next) {
+                char ip[INET6_ADDRSTRLEN] = {0};
+                const void *addr =
+                    a->ai_family == AF_INET6
+                        ? static_cast<const void *>(&reinterpret_cast<sockaddr_in6 *>(a->ai_addr)->sin6_addr)
+                        : static_cast<const void *>(&reinterpret_cast<sockaddr_in *>(a->ai_addr)->sin_addr);
+                if (inet_ntop(a->ai_family, addr, ip, sizeof(ip)) != nullptr) {
+                    if (any) {
+                        entry += ",";
+                    }
+                    entry += ip;
+                    any = true;
+                }
+            }
+            if (res != nullptr) {
+                freeaddrinfo(res);
+            }
+            if (any) {
+                out = curl_slist_append(nullptr, entry.c_str());
+            }
+        }
+    }
+    curl_free(host);
+    curl_free(port);
+    curl_url_cleanup(u);
+    return out;
+}
+} // namespace
+#endif
